---
import ProductCatalog from "./ProductCatalog.astro";

const {
  titleId = "catalog-title",
  mode = "full",
  intro = "Start with the featured release, then move through presets, sample packs, free sounds, and archive material.",
  showGuide = true,
} = Astro.props;

const isCurated = mode === "curated";

const categoryOverview = [
  {
    label: "Preset Packs",
    href: "#catalog-presets",
    text: "Current synth preset releases for Pigments, Vital, Synplant, Moog, Softube, and FabFilter."
  },
  {
    label: "Free Packs",
    href: "#catalog-free",
    text: "Lite versions and free entry points before buying into a full release."
  },
  {
    label: "Sample Packs",
    href: "#catalog-samples",
    text: "WAV textures, effects, atmospheres, percussion, subs, and cinematic beds."
  },
  {
    label: "Archive",
    href: isCurated ? "/sound/#catalog-legacy" : "#catalog-legacy",
    text: "Older legacy material kept available without mixing it into the current catalog."
  }
];
---
<header class="hero">
  <div class="hero-copy">
    <p class="eyebrow">Ambient and cinematic audio</p>
    <h1>Browse Sound</h1>
    <p class="tagline">
      Dark sound packs for tension, melody, and cinematic motion.
    </p>
  </div>
  <div class="hero-actions">
    <a class="button primary" data-track="hero_explore_click" href="#catalog-presets">
      <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
      Browse Preset Packs
    </a>
    <a class="button secondary" data-track="hero_free_click" href="#catalog-free">
      <i class="fa-solid fa-download" aria-hidden="true"></i>
      Download Free Sounds
    </a>
  </div>
</header>

<section class="catalog card" aria-labelledby={titleId}>
  <p class="catalog-intro" id={titleId}>{intro}</p>
  <article class="featured-product" aria-label="Featured product">
    <img
      class="featured-thumb"
      src="/assets/thumbs/black-arcology-thumb.png"
      width="128"
      height="128"
      alt="BLACK ARCOLOGY product artwork"
      loading="eager"
      decoding="async"
    />
    <div class="featured-content">
      <p class="featured-label">Featured</p>
      <h3>BLACK ARCOLOGY - Industrial Presets for Pigments</h3>
      <p>128 darker Pigments presets for industrial drones, evolving keys, and fractured FX.</p>
      <p class="featured-supporting">Built for machine pressure, industrial edge, and cinematic tension without preset-bank gloss.</p>
    </div>
    <div class="featured-actions">
      <a class="button secondary" href="/products/black-arcology/">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        Details
      </a>
      <a
        class="button primary featured-cta"
        data-track="featured_product_click"
        href="https://kreativ.gumroad.com/l/black-arcology-industrial-presets-for-pigments"
        target="_blank"
        rel="noopener noreferrer"
      >
        <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
        Get Pack
      </a>
    </div>
  </article>
  <div class="catalog-overview" aria-label="Catalog overview">
    {categoryOverview.map((item) => (
      <a class="catalog-overview-card" href={item.href}>
        <span>{item.label}</span>
        <small>{item.text}</small>
      </a>
    ))}
  </div>
  {showGuide ? (
    <section class="catalog-guide" aria-label="How to choose a Kreativ Sound pack">
      <div>
        <p class="featured-label">How to choose</p>
        <h2>Start with the sound world you need today.</h2>
        <p>If the catalog feels wide, use these quick entry points before browsing everything.</p>
      </div>
      <div class="catalog-guide-grid">
        <a href="/products/black-arcology/">
          <strong>Dark Pigments pressure</strong>
          <span>Choose Black Arcology for industrial drones, machine tone, melodic keys, and fractured FX.</span>
        </a>
        <a href="/products/velvet-ruins/">
          <strong>Dark Vital melody</strong>
          <span>Choose Velvet Ruins for spectral movement, worn melodic tone, and cinematic Vital presets.</span>
        </a>
        <a href="/products/neolith/">
          <strong>Analog tension</strong>
          <span>Choose NEOLITH when you need Softube Models presets with low-register weight and restrained motion.</span>
        </a>
        <a href="#catalog-free">
          <strong>Test first</strong>
          <span>Start with Free Packs if you want to check the palette before buying a full release.</span>
        </a>
      </div>
    </section>
  ) : null}
  <ProductCatalog
    visibleCategories={isCurated ? ["Presets", "Free", "Samples"] : undefined}
    showCategoryNav={isCurated}
  />
  {isCurated ? (
    <div class="catalog-secondary-links" aria-label="More sound categories">
      <p>Looking for archive releases?</p>
      <div class="catalog-secondary-actions">
        <a class="button secondary" href="/sound/#catalog-legacy">
          <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
          View Archive
        </a>
      </div>
    </div>
  ) : null}
</section>
