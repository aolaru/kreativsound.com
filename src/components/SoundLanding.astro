---
import ProductCatalog from "./ProductCatalog.astro";

const {
  titleId = "catalog-title",
  intro = "Start with the featured release, then move through presets, sample packs, free sounds, and archive material.",
} = Astro.props;
---
<header class="hero">
  <div class="hero-copy">
    <p class="eyebrow">Ambient and cinematic audio</p>
    <h1>Browse Sound</h1>
    <p class="tagline">
      Dark sound packs for tension, melody, and cinematic motion.
    </p>
  </div>
  <div class="hero-actions">
    <a class="button primary" data-track="hero_explore_click" href="#catalog-presets">
      <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
      Browse Preset Packs
    </a>
    <a class="button secondary" data-track="hero_free_click" href="#catalog-free">
      <i class="fa-solid fa-download" aria-hidden="true"></i>
      Get Free Sounds
    </a>
  </div>
</header>

<section class="catalog card" aria-labelledby={titleId}>
  <h2 id={titleId}>Browse Sound</h2>
  <p class="catalog-intro">{intro}</p>
  <article class="featured-product" aria-label="Featured product">
    <img
      class="featured-thumb"
      src="/assets/thumbs/black-arcology-thumb.png"
      width="128"
      height="128"
      alt="BLACK ARCOLOGY product artwork"
      loading="eager"
      decoding="async"
    />
    <div class="featured-content">
      <p class="featured-label">Featured</p>
      <h3>BLACK ARCOLOGY - Industrial Presets for Pigments</h3>
      <p>128 darker Pigments presets for industrial drones, evolving keys, and fractured FX.</p>
      <p class="featured-supporting">Built for machine pressure, industrial edge, and cinematic tension without preset-bank gloss.</p>
    </div>
    <div class="featured-actions">
      <a class="button secondary" href="/products/black-arcology/">
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
        Details
      </a>
      <a
        class="button primary featured-cta"
        data-track="featured_product_click"
        href="https://kreativ.gumroad.com/l/black-arcology-industrial-presets-for-pigments"
        target="_blank"
        rel="noopener noreferrer"
      >
        <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
        Get BLACK ARCOLOGY
      </a>
    </div>
  </article>
  <ProductCatalog />
</section>
