---
const { active = "sound" } = Astro.props;

function navClass(key) {
  return key === active ? "nav-link active" : "nav-link";
}
---
<nav class="site-nav site-nav-split site-nav-home" aria-label="Primary">
  <a class="nav-brand nav-brand-left" href="/" aria-label="Kreativ Sound home">
    <img class="nav-brand-mark" src="/logo-128.svg" width="128" height="128" alt="" aria-hidden="true" />
    <span class="nav-brand-copy" aria-hidden="true">
      <span class="nav-brand-name">Kreativ</span>
      <span class="nav-brand-subname">Sound</span>
    </span>
    <span class="sr-only">Kreativ Sound</span>
  </a>
  <form class="site-search" action="https://www.google.com/search" method="get" role="search">
    <input type="hidden" name="sitesearch" value="kreativsound.com" />
    <label class="sr-only" for="site-search-input">Search Kreativ Sound</label>
    <i class="fa-solid fa-magnifying-glass site-search-icon" aria-hidden="true"></i>
    <input
      class="site-search-input"
      id="site-search-input"
      name="q"
      type="search"
      role="combobox"
      aria-controls="site-search-results"
      aria-expanded="false"
      placeholder="Search site"
      autocomplete="off"
    />
  </form>
  <div class="nav-group nav-group-right">
    <a class={navClass("sound")} href="/sounds/" aria-label="Sounds">Sounds</a>
    <a class={navClass("tools")} href="/tools/">Tools</a>
    <a class={navClass("music")} href="/music/">Music</a>
    <a class={navClass("news")} href="/news/">News</a>
    <a class={navClass("learn")} href="/learn/">Learn</a>
    <a class={navClass("about")} href="/about/">About</a>
    <a class={navClass("contact")} href="/contact/">Contact</a>
    <button class="nav-link theme-toggle" id="theme-toggle" type="button" aria-pressed="false" aria-label="Switch theme" data-icon="moon">
      <i class="theme-icon theme-icon-sun fa-regular fa-sun" aria-hidden="true"></i>
      <i class="theme-icon theme-icon-moon fa-regular fa-moon" aria-hidden="true"></i>
      <span class="sr-only">Toggle theme</span>
    </button>
  </div>
</nav>
