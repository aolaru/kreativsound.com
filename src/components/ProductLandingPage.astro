---
import type { ProductPage } from "../lib/product-pages";

type PurchaseAction = {
  url: string;
  label: string;
  icon: string;
};

const { product } = Astro.props as { product: ProductPage };
const hasDemo = Boolean(product.demo?.src);
const productName = product.headline;
const displaySpecifications = product.price
  ? [
      { label: "Price", value: product.price },
      ...product.specifications.filter((spec) => spec.label.toLowerCase() !== "price")
    ]
  : product.specifications;
const offerUrls = [product.primaryUrl, product.purchaseAltUrl].filter((url): url is string => Boolean(url));
const purchaseActions = [
  product.primaryUrl && product.primaryLabel
    ? { url: product.primaryUrl, label: product.primaryLabel, icon: purchaseIconClass(product.primaryUrl) }
    : null,
  product.purchaseAltUrl && product.purchaseAltLabel
    ? { url: product.purchaseAltUrl, label: product.purchaseAltLabel, icon: purchaseIconClass(product.purchaseAltUrl) }
    : null
].filter(Boolean) as PurchaseAction[];
const toolActions = product.slug === "preset-mutator" && product.secondaryUrl && product.secondaryLabel
  ? [{ url: product.secondaryUrl, label: product.secondaryLabel, icon: "payment-icon payment-icon-app" }]
  : [];

function purchaseIconClass(url?: string) {
  if (url?.includes("paypal.com")) return "payment-icon payment-icon-paypal";
  if (url?.includes("gumroad.com")) return "payment-icon payment-icon-gumroad";
  return "payment-icon payment-icon-shop";
}

function actionClass(index: number) {
  return index === 0 ? "button primary" : "button secondary";
}

function isExternalUrl(url: string) {
  return /^https?:\/\//.test(url);
}

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: productName,
  description: product.description,
  image: product.ogImage,
  brand: {
    "@type": "Brand",
    name: "Kreativ Sound"
  },
  category: product.kicker,
  offers: offerUrls.length
    ? offerUrls.map((url) => ({
          "@type": "Offer",
          url,
          availability: "https://schema.org/InStock",
          ...(product.priceAmount
            ? {
                price: String(product.priceAmount),
                priceCurrency: product.priceCurrency || "EUR"
              }
            : {})
        }))
    : undefined
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Kreativ Sound",
      item: "https://kreativsound.com/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Sounds",
      item: "https://kreativsound.com/sounds/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: productName,
      item: product.canonical
    }
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<article class={`card page-main product-page product-page-landing product-page-${product.variant}`}>
  <header class="product-landing-hero">
    <p class="product-kicker">{product.kicker}</p>
    <h1 class="page-title">{productName}</h1>
    <p class="page-lead">{product.subtitle}</p>

    <figure class="product-landing-media">
      <img class="product-landing-image" src={product.image} width="1040" alt={product.imageAlt} />
    </figure>

    {hasDemo ? (
      <section class="product-landing-demo" aria-label="Audio demo">
        <h2>{product.demo.label || "Audio demo"}</h2>
        {product.demoBlurb ? <p>{product.demoBlurb}</p> : null}
        <audio class="product-card-demo-player" controls preload="metadata">
          <source src={product.demo.src} type={product.demo.type} />
        </audio>
      </section>
    ) : null}

    {purchaseActions.length ? (
      <div class="product-landing-actions" aria-label="Purchase options">
        {purchaseActions.map((action, index) => (
          <a class={actionClass(index)} href={action.url} target="_blank" rel="noopener noreferrer">
            <span class={action.icon} aria-hidden="true"></span>
            {action.label}
          </a>
        ))}
        {toolActions.map((action) => (
          <a class="button secondary" href={action.url}>
            <span class={action.icon} aria-hidden="true"></span>
            {action.label}
          </a>
        ))}
      </div>
    ) : null}

    {product.price ? <p class="product-price-line"><strong>{product.price}</strong> - Instant download</p> : null}
    {product.shortMeta ? <p class="product-landing-meta">{product.shortMeta}</p> : null}
  </header>

  {product.longDescription.length ? (
    <section class="product-landing-section product-description-section" aria-labelledby="product-description-title">
      <h2 id="product-description-title">Description</h2>
      <div class="product-long-description">
        {product.longDescription.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>
  ) : null}

  {product.liteComparison ? (
    <section class="product-landing-section product-lite-comparison" aria-labelledby="product-lite-comparison-title">
      <div class="product-lite-comparison-head">
        <p class="product-section-kicker">Lite vs Full</p>
        <h2 id="product-lite-comparison-title">{product.liteComparison.title}</h2>
        <p>{product.liteComparison.intro}</p>
      </div>
      <div class="product-lite-comparison-table-wrap">
        <table class="product-lite-comparison-table">
          <thead>
            <tr>
              <th scope="col">Feature</th>
              <th scope="col">{product.liteComparison.liteLabel}</th>
              <th scope="col">{product.liteComparison.fullLabel}</th>
            </tr>
          </thead>
          <tbody>
            {product.liteComparison.rows.map((row) => (
              <tr>
                <th scope="row">{row.label}</th>
                <td data-label={product.liteComparison?.liteLabel}>{row.lite}</td>
                <td class="product-lite-comparison-full" data-label={product.liteComparison?.fullLabel}>{row.full}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="product-lite-upgrade">
        {product.liteComparison.note ? <p>{product.liteComparison.note}</p> : null}
        <div class="product-landing-actions">
          <a
            class="button primary"
            href={product.liteComparison.upgradeUrl}
            target={isExternalUrl(product.liteComparison.upgradeUrl) ? "_blank" : undefined}
            rel={isExternalUrl(product.liteComparison.upgradeUrl) ? "noopener noreferrer" : undefined}
          >
            <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
            {product.liteComparison.upgradeLabel}
          </a>
          {product.liteComparison.secondaryUrl && product.liteComparison.secondaryLabel ? (
            <a
              class="button secondary"
              href={product.liteComparison.secondaryUrl}
              target={isExternalUrl(product.liteComparison.secondaryUrl) ? "_blank" : undefined}
              rel={isExternalUrl(product.liteComparison.secondaryUrl) ? "noopener noreferrer" : undefined}
            >
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              {product.liteComparison.secondaryLabel}
            </a>
          ) : null}
        </div>
      </div>
    </section>
  ) : null}

  {product.includedGroups.length ? (
    <section class="product-landing-section product-included-section" aria-labelledby="product-included-title">
      <h2 id="product-included-title">What's Included</h2>
      <div class="product-included-groups">
        {product.includedGroups.map((group) => (
          <section class="product-included-group" aria-label={group.title}>
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => (
                <li>
                  {item.url ? <a href={item.url}>{item.name}</a> : <strong>{item.name}</strong>}
                  <span>{item.detail}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </section>
  ) : null}

  {displaySpecifications.length ? (
    <section class="product-landing-section" aria-labelledby="product-specifications-title">
      <h2 id="product-specifications-title">Product Specifications</h2>
      <dl class="product-specification-list">
        {displaySpecifications.map((spec) => (
          <div>
            <dt>{spec.label}</dt>
            <dd>{spec.value}</dd>
          </div>
        ))}
      </dl>
    </section>
  ) : null}

  {product.requirements.length ? (
    <section class="product-landing-section" aria-labelledby="product-requirements-title">
      <h2 id="product-requirements-title">Requirements</h2>
      <div class="product-requirements-copy">
        {product.requirements.map((requirement) => <p>{requirement}</p>)}
      </div>
    </section>
  ) : null}

  {purchaseActions.length || product.finalCtaTitle || product.finalCtaText ? (
    <section class="product-final-cta" aria-labelledby="product-final-cta-title">
      <h2 id="product-final-cta-title">{product.finalCtaTitle || `Ready to download ${productName}?`}</h2>
      <p>{product.finalCtaText || product.ctaLine || product.description}</p>
      {purchaseActions.length ? (
        <div class="product-landing-actions">
          {purchaseActions.map((action, index) => (
            <a class={actionClass(index)} href={action.url} target="_blank" rel="noopener noreferrer">
              <span class={action.icon} aria-hidden="true"></span>
              {action.label}
            </a>
          ))}
          {toolActions.map((action) => (
            <a class="button secondary" href={action.url}>
              <span class={action.icon} aria-hidden="true"></span>
              {action.label}
            </a>
          ))}
        </div>
      ) : null}
    </section>
  ) : null}
</article>
