---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { musicArtists } from "../../lib/music";
import type { MusicRelease } from "../../lib/music";

const siteUrl = "https://kreativsound.com";
const allReleaseItems = musicArtists.flatMap((artist) =>
  artist.releases.map((release) => ({ artist, release }))
);
const featuredItem = allReleaseItems.find(({ release }) => release.featured) ?? allReleaseItems[0];

function primaryReleaseLink(release: MusicRelease) {
  return release.platformLinks?.find((link) => link.primary) ?? release.platformLinks?.[0] ?? {
    label: release.linkLabel,
    href: release.href,
  };
}

function absoluteUrl(href: string) {
  return href.startsWith("http") ? href : `${siteUrl}${href}`;
}

function formattedDate(date: string) {
  return new Date(`${date}T00:00:00Z`).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  });
}

const musicJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Music | Kreativ Sound",
  description: "Artist releases and studies made with the Kreativ Sound sample, preset, and texture catalog.",
  url: `${siteUrl}/music/`,
  mainEntity: allReleaseItems.map(({ artist, release }) => ({
    "@type": release.type === "Album" ? "MusicAlbum" : "MusicRecording",
    name: release.title,
    byArtist: {
      "@type": "MusicGroup",
      name: artist.name,
      url: artist.platformHref,
    },
    image: absoluteUrl(release.image),
    url: primaryReleaseLink(release).href,
    sameAs: release.platformLinks?.map((link) => link.href) ?? [release.href],
    ...(release.releaseDate ? { datePublished: release.releaseDate } : {}),
  })),
};
---
<BaseLayout
  title="Music | Kreativ Sound"
  description="Artist releases and studies made with the Kreativ Sound sample, preset, and texture catalog."
  canonical="https://kreativsound.com/music/"
  ogImage="https://kreativsound.com/assets/music/rethyn-holo-signal.jpg"
  ogImageAlt="Holo Signal cover art"
  activeNav="music"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(musicJsonLd)}></script>
  <section class="card page-main music-page-modern">
    <div class="music-hero">
      <div class="music-hero-copy">
        <p class="eyebrow">Music</p>
        <h1 class="page-title">Music built from the Kreativ Sound palette.</h1>
        <p class="page-lead">Olaru and Rethyn are personal music projects by Andrei Olaru, built with Kreativ Sound samples, presets, drones, and texture layers.</p>
        <p class="music-hero-note">Follow the releases across ambient, melodic, and darker electronic directions.</p>
      </div>
      {featuredItem ? (
        <section class="music-feature" aria-labelledby="featured-music-title">
          <a
            class="music-feature-art"
            href={primaryReleaseLink(featuredItem.release).href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Listen to ${featuredItem.release.title}`}
          >
            <img
              src={featuredItem.release.image}
              width="354"
              height="354"
              alt={featuredItem.release.imageAlt}
            />
          </a>
          <div class="music-feature-copy">
            <p class="product-section-kicker">Featured listening</p>
            <h2 id="featured-music-title">{featuredItem.release.title}</h2>
            <p class="music-feature-meta">
              {featuredItem.artist.name}
              {featuredItem.release.releaseDate ? ` · ${formattedDate(featuredItem.release.releaseDate)}` : ""}
            </p>
            <p>{featuredItem.release.summary}</p>
            {featuredItem.release.mood?.length ? (
              <div class="music-mood-list" aria-label={`${featuredItem.release.title} mood`}>
                {featuredItem.release.mood.map((mood) => <span>{mood}</span>)}
              </div>
            ) : null}
            {featuredItem.release.platformLinks?.length ? (
              <div class="music-feature-actions" aria-label={`${featuredItem.release.title} listening links`}>
                {featuredItem.release.platformLinks.map((link) => (
                  <a
                    class:list={["button", link.primary ? "primary" : "secondary"]}
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                    {link.label}
                  </a>
                ))}
              </div>
            ) : null}
          </div>
        </section>
      ) : null}
    </div>

    <div class="music-artist-stack">
      {musicArtists.map((artist) => (
        <section
          class:list={["music-artist-shell", artist.shellClass]}
          aria-labelledby={`${artist.slug}-heading`}
        >
          <div class="music-artist-head">
            <div>
              <p class="learn-card-kicker">Artist</p>
              <h2 id={`${artist.slug}-heading`}>{artist.name}</h2>
              <p class="music-artist-intro">{artist.intro}</p>
            </div>
            <a
              class="button secondary"
              href={artist.platformHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
              {artist.platformLabel}
            </a>
          </div>
          <div class:list={["music-grid", artist.gridClass]}>
            {artist.releases.map((release) => (
              <article
                class:list={[
                  "music-card",
                  artist.gridClass === "music-grid-single" && "music-card-featured",
                ]}
              >
                <a
                  class="music-card-art-link"
                  href={primaryReleaseLink(release).href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Listen to ${release.title}`}
                >
                  <img
                    class="music-card-image"
                    src={release.image}
                    width="350"
                    height="350"
                    alt={release.imageAlt}
                    loading="lazy"
                  />
                </a>
                <div class="music-card-body">
                  <span class="learn-card-kicker">{release.type}</span>
                  <a
                    class="music-card-title"
                    href={primaryReleaseLink(release).href}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {release.title}
                  </a>
                  {release.meta?.length ? (
                    <span class="music-card-meta">
                      {release.meta.map((item) => <span>{item}</span>)}
                    </span>
                  ) : null}
                  <p class="music-card-summary">{release.summary}</p>
                  <span class="music-card-links">
                    {(release.platformLinks ?? [{ label: release.linkLabel, href: release.href, primary: true }]).map((link) => (
                      <a
                        class:list={["music-card-link", link.primary && "is-primary"]}
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.label}{" "}
                        <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                      </a>
                    ))}
                  </span>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
