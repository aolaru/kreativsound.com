---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { musicArtists } from "../../lib/music";
---
<BaseLayout
  title="Music | Kreativ Sound"
  description="Music studies, atmospheres, and selected pieces from Kreativ Sound."
  canonical="https://kreativsound.com/music/"
  activeNav="music"
>
  <section class="card page-main music-page-modern">
    <div class="music-hero">
      <div class="music-hero-copy">
        <p class="eyebrow">Music</p>
        <h1 class="page-title">Artist pages tied to the wider sound world.</h1>
        <p class="page-lead">Olaru and Rethyn are both personal music projects by Andrei Olaru, built with heavy use of Kreativ Sound samples, sounds, and presets.</p>
      </div>
      <div class="music-hero-panel">
        <p class="product-section-kicker">Listening paths</p>
        <h2>Two artist directions</h2>
        <p><strong>Olaru</strong> carries the ambient and melodic side. <strong>Rethyn</strong> carries the darker, signal-shaped electronic direction. Both pull directly from the same Kreativ Sound palette used across the catalog.</p>
      </div>
    </div>

    <div class="music-artist-stack">
      {musicArtists.map((artist) => (
        <section
          class:list={["music-artist-shell", artist.shellClass]}
          aria-labelledby={`${artist.slug}-heading`}
        >
          <div class="music-artist-head">
            <div>
              <p class="learn-card-kicker">Artist</p>
              <h2 id={`${artist.slug}-heading`}>{artist.name}</h2>
              <p class="music-artist-intro">{artist.intro}</p>
            </div>
            <a
              class="button secondary"
              href={artist.platformHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
              {artist.platformLabel}
            </a>
          </div>
          <div class:list={["music-grid", artist.gridClass]}>
            {artist.releases.map((release) => (
              <a
                class:list={[
                  "music-card",
                  artist.gridClass === "music-grid-single" && "music-card-featured",
                ]}
                href={release.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  class="music-card-image"
                  src={release.image}
                  alt={release.imageAlt}
                  loading="lazy"
                />
                <span class="learn-card-kicker">{release.type}</span>
                <h3>{release.title}</h3>
                <p>{release.summary}</p>
                <span class="music-card-link">
                  {release.linkLabel}{" "}
                  <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
