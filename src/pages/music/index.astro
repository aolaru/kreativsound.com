---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Music | Kreativ Sound"
  description="Music studies, atmospheres, and selected pieces from Kreativ Sound."
  canonical="https://kreativsound.com/music/"
  activeNav="music"
>
  <section class="card page-main">
    <h1 class="page-title">Music</h1>
    <p class="page-lead">Artist pages, albums, and selected listening paths connected to the wider Kreativ Sound world.</p>
    <div class="music-page">
      <section class="music-section" aria-labelledby="olaru-heading">
        <div class="music-section-head">
          <div>
            <p class="learn-card-kicker">Artist</p>
            <h2 id="olaru-heading">Olaru</h2>
          </div>
          <a class="learn-card-link" href="https://olaru.bandcamp.com/" target="_blank" rel="noopener noreferrer">
            Visit Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
          </a>
        </div>
        <p class="music-section-intro">Ambient pieces, studies, and melodic sketches published on Bandcamp.</p>
        <div class="music-grid">
          <a class="music-card" href="https://olaru.bandcamp.com/album/memories" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a1549831212_2.jpg" alt="Memories album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Memories</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
          <a class="music-card" href="https://olaru.bandcamp.com/album/trees" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a0092871322_2.jpg" alt="Trees album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Trees</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
          <a class="music-card" href="https://olaru.bandcamp.com/album/vision-no-return" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a1511504117_2.jpg" alt="Vision No Return album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Vision No Return</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
          <a class="music-card" href="https://olaru.bandcamp.com/album/nightfall" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a1183385430_2.jpg" alt="Nightfall album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Nightfall</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
          <a class="music-card" href="https://olaru.bandcamp.com/album/selected-ghosts" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a1961746094_2.jpg" alt="Selected Ghosts album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Selected Ghosts</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
          <a class="music-card" href="https://olaru.bandcamp.com/album/ambitones" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://f4.bcbits.com/img/a2196578473_2.jpg" alt="Ambitones album cover" loading="lazy" />
            <span class="learn-card-kicker">Album</span>
            <h3>Ambitones</h3>
            <span class="music-card-link">Open on Bandcamp <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
        </div>
      </section>

      <section class="music-section music-section-placeholder" aria-labelledby="rethyn-heading">
        <div class="music-section-head">
          <div>
            <p class="learn-card-kicker">Artist</p>
            <h2 id="rethyn-heading">Rethyn</h2>
          </div>
          <a class="learn-card-link" href="https://open.spotify.com/artist/7iwBaUeCQYimysZAoKh42X" target="_blank" rel="noopener noreferrer">
            Open Spotify <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
          </a>
        </div>
        <p class="music-section-intro">Electronic sketches and signal-driven pieces under the Rethyn moniker, starting with the first released single.</p>
        <div class="music-grid">
          <a class="music-card" href="https://music.amazon.com/artists/B0GV4RM888/rethyn" target="_blank" rel="noopener noreferrer">
            <img class="music-card-image" src="https://m.media-amazon.com/images/I/31zy-G17D-L._SX354_SY354_BL0_QL100__UXNaN_FMjpg_QL85_.jpg" alt="Holo Signal cover" loading="lazy" />
            <span class="learn-card-kicker">Single</span>
            <h3>Holo Signal</h3>
            <p>Released March 27, 2026. Includes <strong>Holo Signal</strong> and <strong>Holo Drift</strong>.</p>
            <span class="music-card-link">Open artist page <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i></span>
          </a>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
