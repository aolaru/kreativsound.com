---
import { productPages } from "../../lib/product-pages";

export function getStaticPaths() {
  return productPages.map((product) => ({
    params: { slug: product.slug },
    props: { target: `/sounds/${product.slug}`, title: product.headline }
  }));
}

const { target, title } = Astro.props;
const canonical = `https://kreativsound.com${target}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting to {title} | Kreativ Sound</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <!-- Cloudflare Web Analytics --><script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "4d2ef2573cb8456282aa65a1d9defd9d"}'></script><!-- End Cloudflare Web Analytics -->
    <script is:inline set:html={`window.location.replace(${JSON.stringify(target)});`} />
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>.</p>
  </body>
</html>
