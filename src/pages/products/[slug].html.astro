---
import { productPages } from "../../lib/product-pages";

export function getStaticPaths() {
  return productPages.map((product) => ({
    params: { slug: product.slug }
  }));
}

const target = `/sounds/${Astro.params.slug}`;
const canonical = `https://kreativsound.com${target}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting | Kreativ Sound</title>
    <meta name="robots" content="noindex,follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <script is:inline set:html={`window.location.replace(${JSON.stringify(target)});`} />
  </head>
  <body>
    <p>Redirecting to <a href={target}>{target}</a>.</p>
  </body>
</html>
