---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { productPages } from "../../../lib/product-pages";

export function getStaticPaths() {
  return productPages.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const [primaryPanel, ...secondaryPanels] = product.panels;
---
<BaseLayout
  title={product.title}
  description={product.description}
  canonical={product.canonical}
  ogImage={product.ogImage}
  ogImageAlt={product.ogImageAlt}
  activeNav="sound"
>
  <article class="card page-main product-page product-page-modern">
    <section class="product-hero">
      <div class="product-hero-copy">
        <p class="product-kicker">{product.kicker}</p>
        <h1 class="page-title">{product.title.replace(" | Kreativ Sound", "")}</h1>
        <p class="page-lead">{product.lead}</p>
        <p class="product-summary">{product.summary}</p>
        <div class="product-specs-inline" aria-label="Product summary">
          {product.specs.map((spec) => (
            <div class="product-spec-inline">
              <span class="product-spec-label">{spec.label}</span>
              <span class="product-spec-value">{spec.value}</span>
            </div>
          ))}
        </div>
        <div class="product-actions">
          <a class="button primary" href={product.primaryUrl} target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
            Buy on Gumroad
          </a>
          <a class="button secondary" href={product.secondaryUrl}>
            <i class="fa-solid fa-book-open" aria-hidden="true"></i>
            {product.secondaryLabel}
          </a>
        </div>
        <p class="product-trust-line">Instant access. Independent release. Built for darker, cinematic workflow use.</p>
      </div>

      <div class="product-hero-media">
        <div class="product-cover-frame">
          <img class="product-hero-image" src={product.image} width="320" height="320" alt={product.imageAlt} />
        </div>
        <section class="product-demo" aria-label="Audio demo">
          <div class="product-demo-header">
            <span class="product-demo-title"><i class="fa-solid fa-wave-square" aria-hidden="true"></i> Demo</span>
            <span class="product-demo-note">{product.demo?.src ? "Listen now" : "Audio slot ready"}</span>
          </div>
          {product.demo?.src ? (
            <div class="product-card-demo">
              <span class="product-card-demo-label">{product.demo.label || "Listen to demo"}</span>
              <audio class="product-card-demo-player" controls preload="metadata">
                <source src={product.demo.src} type={product.demo.type} />
              </audio>
            </div>
          ) : (
            <p class="product-demo-placeholder">{product.demoPlaceholder}</p>
          )}
        </section>
      </div>
    </section>

    <section class="stack">
      {primaryPanel ? (
        <section class="product-feature">
          <div class="product-feature-copy">
            <p class="product-section-kicker">Why this pack</p>
            <h2>{primaryPanel.title}</h2>
            {primaryPanel.body ? <p>{primaryPanel.body}</p> : null}
          </div>
          <div class="product-feature-support">
            <p class="product-section-kicker">Best use</p>
            <p>{product.summary}</p>
          </div>
        </section>
      ) : null}

      <section class="product-story-grid">
        {secondaryPanels.map((panel) => (
          <section class="product-panel product-panel-modern">
            <p class="product-section-kicker">{panel.title}</p>
            <h2>{panel.title}</h2>
            {panel.body ? <p>{panel.body}</p> : null}
            {panel.items ? (
              <ul>
                {panel.items.map((item) => <li>{item}</li>)}
              </ul>
            ) : null}
          </section>
        ))}

        <section class="product-panel product-panel-modern product-panel-accent">
          <p class="product-section-kicker">Related</p>
          <h2>Use it in context</h2>
          <div class="product-related">
            {product.related.map((item) => (
              <a href={item.url}>{item.label} <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
            ))}
          </div>
        </section>
      </section>

      <section class="product-cta-band">
        <div>
          <p class="product-section-kicker">Ready to use it</p>
          <h2>{product.title.replace(" | Kreativ Sound", "")}</h2>
          <p class="product-summary">{product.summary}</p>
        </div>
        <div class="product-actions">
          <a class="button primary" href={product.primaryUrl} target="_blank" rel="noopener noreferrer">
            <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
            Buy on Gumroad
          </a>
        </div>
      </section>
    </section>
  </article>
</BaseLayout>
