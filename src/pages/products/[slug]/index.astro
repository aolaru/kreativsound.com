---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { productPages } from "../../../lib/product-pages";

export function getStaticPaths() {
  return productPages.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const [primaryPanel, ...secondaryPanels] = product.panels;
const hasDemo = Boolean(product.demo?.src);
---
<BaseLayout
  title={product.title}
  description={product.description}
  canonical={product.canonical}
  ogImage={product.ogImage}
  ogImageAlt={product.ogImageAlt}
  activeNav="sound"
>
  <article class={`card page-main product-page product-page-modern product-page-${product.variant}`}>
    <section class="product-hero">
      <div class="product-hero-copy">
        <p class="product-kicker">{product.kicker}</p>
        <h1 class="page-title">{product.title.replace(" | Kreativ Sound", "")}</h1>
        <p class="page-lead">{product.lead}</p>
        <p class="product-summary">{product.summary}</p>
        <p class="product-hero-note">{product.heroNote}</p>
        <div class="product-specs-inline" aria-label="Product summary">
          {product.specs.map((spec) => (
            <div class="product-spec-inline">
              <span class="product-spec-label">{spec.label}</span>
              <span class="product-spec-value">{spec.value}</span>
            </div>
          ))}
        </div>
        <p class="product-trust-line">
          {product.variant === "archive"
            ? "Archive entry. Preserved for catalog history and earlier workflow reference."
            : product.variant === "free"
              ? "Free release. Direct download and immediate use."
              : "Instant access. Independent release. Built for darker, cinematic workflow use."}
        </p>
      </div>

      <div class="product-hero-media">
        <div class="product-cover-frame">
          <img class="product-hero-image" src={product.image} width="320" height="320" alt={product.imageAlt} />
        </div>
        <div class="product-media-actions">
          {product.primaryUrl && product.primaryLabel ? (
            <a class="button primary" href={product.primaryUrl} target="_blank" rel="noopener noreferrer">
              <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
              {product.primaryLabel}
            </a>
          ) : null}
          {product.liteUrl ? (
            <a class="button secondary" href={product.liteUrl}>
              <i class="fa-solid fa-download" aria-hidden="true"></i>
              {product.liteLabel || "Download Lite"}
            </a>
          ) : null}
        </div>
        {product.valueLine ? (
          <p class="product-value-line">{product.valueLine}</p>
        ) : null}
        {product.liteUrl ? (
          <p class="product-lite-note">{product.liteNote || "Prefer to test the sound first? Start with the free Lite version."}</p>
        ) : null}
      </div>
    </section>

    <section class="stack">
      {hasDemo && (
        <section class="product-demo product-demo-spotlight" aria-label="Audio demo">
          <div class="product-demo-copy">
            <p class="product-section-kicker">Hear the pack</p>
            <h2>{product.demo.label || "Listen to demo"}</h2>
            <p>{product.demoBlurb}</p>
          </div>
          <div class="product-demo-player-wrap">
            <audio class="product-card-demo-player" controls preload="metadata">
              <source src={product.demo.src} type={product.demo.type} />
            </audio>
          </div>
        </section>
      )}

      {primaryPanel ? (
        <section class="product-feature">
          <div class="product-feature-copy">
            <p class="product-section-kicker">Why this pack</p>
            <h2>{primaryPanel.title}</h2>
            {primaryPanel.body ? <p>{primaryPanel.body}</p> : null}
          </div>
          <div class="product-feature-support">
            <p class="product-section-kicker">Best use</p>
            <p>{product.summary}</p>
          </div>
        </section>
      ) : null}

      <section class="product-story-grid">
        {secondaryPanels.map((panel) => (
          <section class="product-panel product-panel-modern">
            <h2>{panel.title}</h2>
            {panel.body ? <p>{panel.body}</p> : null}
            {panel.items ? (
              <ul>
                {panel.items.map((item) => <li>{item}</li>)}
              </ul>
            ) : null}
          </section>
        ))}

        <section class="product-panel product-panel-modern product-panel-accent">
          <p class="product-section-kicker">Related</p>
          <h2>Use it in context</h2>
          <div class="product-related">
            {product.related.map((item) => (
              <a href={item.url}>{item.label} <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
            ))}
          </div>
        </section>
      </section>

      <section class="product-cta-strip">
        <div class="product-cta-copy">
          <p class="product-section-kicker">{product.variant === "archive" ? "Archive entry" : "Ready when you are"}</p>
          <p class="product-cta-line">
            {product.variant === "archive"
              ? "Use the detail page for context, then jump back into the broader archive when you need older material."
              : product.ctaLine || product.heroNote}
          </p>
        </div>
        <div class="product-actions">
          {product.primaryUrl && product.primaryLabel ? (
            <a class="button primary" href={product.primaryUrl} target="_blank" rel="noopener noreferrer">
              <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
              {product.primaryLabel}
            </a>
          ) : null}
          {product.variant === "archive" ? (
            <a class="button secondary" href={product.secondaryUrl}>
              <i class="fa-solid fa-box-archive" aria-hidden="true"></i>
              {product.secondaryLabel}
            </a>
          ) : null}
        </div>
      </section>
    </section>
  </article>
</BaseLayout>
