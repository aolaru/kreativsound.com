---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCatalog from "../../components/ProductCatalog.astro";
---
<BaseLayout
  title="Sound | Kreativ Sound"
  description="Atmospheric sound packs and audio textures for filmmakers, designers, and creators. Crafted for focus, mood, and creative flow."
  canonical="https://kreativsound.com/sound/"
  activeNav="sound"
  bodyClass="home-page"
  skipLinkTarget="#catalog-title"
  skipLinkLabel="Skip to product catalog"
>
  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Ambient and cinematic audio</p>
      <h1>Browse Sound</h1>
      <p class="tagline">
        Atmospheric sound packs and audio textures crafted for focus, mood, and creative flow.
      </p>
    </div>
    <div class="hero-actions">
      <a class="button primary" data-track="hero_explore_click" href="https://kreativ.gumroad.com" target="_blank" rel="noopener noreferrer">
        <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
        Explore Sound Packs
      </a>
      <a class="button secondary" data-track="hero_patreon_click" href="https://www.patreon.com/kreativsound" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-patreon" aria-hidden="true"></i>
        Join Patreon
      </a>
    </div>
  </header>

  <section class="catalog card" aria-labelledby="catalog-title">
    <h2 id="catalog-title">Browse Sound</h2>
    <p class="catalog-intro">Jump to the format you want first.</p>
    <article class="featured-product" aria-label="Featured product">
      <img
        class="featured-thumb"
        src="/assets/thumbs/velvet-ruins.jpg"
        width="96"
        height="96"
        alt="VELVET RUINS product artwork"
        loading="eager"
        decoding="async"
      />
      <div class="featured-content">
        <p class="featured-label">Featured</p>
        <h3>VELVET RUINS - Presets for Vital spectral synth</h3>
        <p>Worn-down cinematic synth textures shaped for dark melody, atmosphere, and motion.</p>
      </div>
      <div class="featured-actions">
        <a class="button secondary" href="/products/velvet-ruins/">
          <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
          Details
        </a>
        <a
          class="button primary featured-cta"
          data-track="featured_product_click"
          href="https://kreativ.gumroad.com/l/velvet-ruins-vital-synth-presets?layout=profile"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
          Get VELVET RUINS
        </a>
      </div>
    </article>
    <ProductCatalog />
  </section>
</BaseLayout>
