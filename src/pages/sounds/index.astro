---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SoundLanding from "../../components/SoundLanding.astro";
---
<BaseLayout
  title="Sounds | Kreativ Sound"
  description="Atmospheric sound packs and audio textures for filmmakers, designers, and creators. Crafted for focus, mood, and creative flow."
  canonical="https://kreativsound.com/sounds/"
  activeNav="sound"
  bodyClass="home-page"
  skipLinkTarget="#catalog-title"
  skipLinkLabel="Skip to product catalog"
>
  <SoundLanding
    intro="Browse the current Kreativ Sound preset banks, sample packs, free sounds, and archive releases."
    showGuide={false}
    showFeatured={false}
    showHeroActions={false}
    showProof={false}
    visibleCategories={["Presets", "Samples", "Free", "Legacy"]}
  />
</BaseLayout>
