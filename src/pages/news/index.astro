---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const newsPosts = (await getCollection("posts", ({ data }) => data.section === "news" && !data.draft))
  .sort((a, b) => (b.data.published || "").localeCompare(a.data.published || ""));

const releasePosts = newsPosts.filter((post) => post.data.kind === "release");
const sitePosts = newsPosts.filter((post) => post.data.kind === "site");

const leadRelease = releasePosts[0];
const moreReleases = releasePosts.slice(1);

function hrefFor(post) {
  return `/posts/${post.id.replace(/\.md$/, ".html")}`;
}

function formatDate(date) {
  return new Date(date).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
}
---
<BaseLayout
  title="News | Kreativ Sound"
  description="Latest sound releases and important updates from Kreativ Sound."
  canonical="https://kreativsound.com/news/"
  activeNav="news"
  ogImage={leadRelease?.data.ogImage || "https://kreativsound.com/assets/thumbs/velvet-ruins.jpg"}
>
  <section class="card page-main news-page">
    <div class="news-hero">
      <div class="news-hero-copy">
        <p class="eyebrow">News</p>
        <h1 class="page-title">Release updates and studio notes.</h1>
        <p class="page-lead">New packs, free drops, and focused site updates from Kreativ Sound.</p>
      </div>

      {leadRelease ? (
        <article class="news-featured">
          <a class="news-featured-media" href={hrefFor(leadRelease)} aria-label={`Read ${leadRelease.data.title}`}>
            <img
              class="news-featured-thumb"
              src={new URL(leadRelease.data.ogImage || "https://kreativsound.com/og-image.svg").pathname}
              alt={`${leadRelease.data.title} artwork`}
              width="320"
              height="180"
              loading="eager"
              decoding="async"
            />
          </a>
          <div class="news-featured-copy">
            <p class="featured-label">Latest release</p>
            <h2>{leadRelease.data.title}</h2>
            <time datetime={leadRelease.data.published}>{formatDate(leadRelease.data.published)}</time>
            <p>{leadRelease.data.description}</p>
            <a class="button primary" href={hrefFor(leadRelease)}>
              <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
              Read release
            </a>
          </div>
        </article>
      ) : null}
    </div>

    <div class="news-sections">
      <article class="news-panel">
        <div class="news-panel-head">
          <p class="product-section-kicker">Releases</p>
          <h2>Latest Sound Releases</h2>
          <p>Recent preset packs, sample releases, and free drops.</p>
        </div>
        <ul class="news-card-list">
          {moreReleases.map((post) => (
            <li class="news-card">
              <time datetime={post.data.published}>{formatDate(post.data.published)}</time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <a href={hrefFor(post)}>Read update <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
            </li>
          ))}
        </ul>
      </article>

      <article class="news-panel">
        <div class="news-panel-head">
          <p class="product-section-kicker">Site</p>
          <h2>Important Site News</h2>
          <p>Workflow changes, tooling updates, and public-facing platform notes.</p>
        </div>
        <ul class="news-card-list">
          {sitePosts.map((post) => (
            <li class="news-card">
              <time datetime={post.data.published}>{formatDate(post.data.published)}</time>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <a href={hrefFor(post)}>Read update <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></a>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
