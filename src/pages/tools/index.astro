---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Tools | Kreativ Sound"
  description="Kreativ Sound browser tools for local-first preset generation and audio sample preparation."
  canonical="https://kreativsound.com/tools/"
  activeNav="tools"
>
  <section class="card page-main product-page tools-page">
    <div class="stack">
      <section class="tools-feature-card" aria-labelledby="tools-title">
        <div class="tools-feature-copy">
          <p class="product-kicker">Current tool</p>
          <h1 id="tools-title" class="page-title">Preset Mutator</h1>
          <p class="page-lead">Create Vital preset starts from scratch ideas, existing presets, or one short audio source.</p>
          <p class="product-summary">Preset Mutator is a local-first browser tool for quick Vital sketches. Free mode creates small batches; Pro adds larger batches and ZIP export.</p>
          <dl class="tools-feature-meta" aria-label="Preset Mutator facts">
            <div>
              <dt>Format</dt>
              <dd>Browser tool</dd>
            </div>
            <div>
              <dt>Synth</dt>
              <dd>Vital</dd>
            </div>
            <div>
              <dt>Free</dt>
              <dd>3 starts</dd>
            </div>
            <div>
              <dt>Pro</dt>
              <dd>32 + ZIP</dd>
            </div>
          </dl>
          <div class="product-actions tools-feature-actions">
            <a class="button primary" href="/preset-mutator/">
              <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
              Open Preset Mutator
            </a>
            <a class="button secondary" href="/tools/preset-mutator/">
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              Product Details
            </a>
            <a class="button secondary" href="https://kreativ.gumroad.com/l/preset-mutator" target="_blank" rel="noopener noreferrer">
              <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
              Buy Pro
            </a>
          </div>
        </div>
        <a class="tools-feature-media" href="/preset-mutator/" aria-label="Open Preset Mutator">
          <img src="/assets/thumbs/preset-mutator.webp" width="720" height="405" alt="Preset Mutator cover artwork" loading="eager" decoding="async" />
        </a>
      </section>

      <section class="tools-feature-card" aria-labelledby="sample-prep-title">
        <div class="tools-feature-copy">
          <p class="product-kicker">POC browser tool</p>
          <h2 id="sample-prep-title" class="page-title">Kreativ Sample Prep</h2>
          <p class="page-lead">Local audio cleanup for sound designers and sample-pack makers.</p>
          <p class="product-summary">Drop in messy WAV files, trim silence, fade, normalize, inspect warnings, and export clean single files or ZIP packs without uploading audio.</p>
          <dl class="tools-feature-meta" aria-label="Kreativ Sample Prep facts">
            <div>
              <dt>Format</dt>
              <dd>Browser tool</dd>
            </div>
            <div>
              <dt>Input</dt>
              <dd>WAV files</dd>
            </div>
            <div>
              <dt>Export</dt>
              <dd>WAV + ZIP</dd>
            </div>
            <div>
              <dt>Privacy</dt>
              <dd>Local only</dd>
            </div>
          </dl>
          <div class="product-actions tools-feature-actions">
            <a class="button primary" href="/tools/kreativ-sample-prep/">
              <i class="fa-solid fa-wave-square" aria-hidden="true"></i>
              Open Sample Prep
            </a>
          </div>
        </div>
        <a class="tools-feature-media" href="/tools/kreativ-sample-prep/" aria-label="Open Kreativ Sample Prep">
          <img src="/assets/thumbs/kreativ-sample-prep.jpg" width="1440" height="810" alt="Kreativ Sample Prep cover artwork showing waveform cleanup and sample export" loading="lazy" decoding="async" />
        </a>
      </section>
    </div>
  </section>
</BaseLayout>
