---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Tools | Kreativ Sound"
  description="Preset Mutator is the current Kreativ Sound browser tool for creating synth presets from scratch ideas, existing presets, or audio."
  canonical="https://kreativsound.com/tools/"
  activeNav="tools"
>
  <section class="card page-main product-page tools-page">
    <div class="stack">
      <section class="tools-feature-card" aria-labelledby="tools-title">
        <div class="tools-feature-copy">
          <p class="product-kicker">Current tool</p>
          <h1 id="tools-title" class="page-title">Preset Mutator</h1>
          <p class="page-lead">Create Vital preset starts from scratch ideas, existing presets, or one short audio source.</p>
          <p class="product-summary">Preset Mutator is a local-first browser tool for fast sound-design sketching. Free mode stays useful; Pro focuses on larger batches and ZIP export.</p>
          <dl class="tools-feature-meta" aria-label="Preset Mutator facts">
            <div>
              <dt>Format</dt>
              <dd>Browser tool</dd>
            </div>
            <div>
              <dt>Synth</dt>
              <dd>Vital</dd>
            </div>
            <div>
              <dt>Free</dt>
              <dd>3 starts</dd>
            </div>
            <div>
              <dt>Pro</dt>
              <dd>32 + ZIP</dd>
            </div>
          </dl>
          <div class="product-actions tools-feature-actions">
            <a class="button primary" href="/apps/preset-mutator/ui/">
              <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
              Open Preset Mutator
            </a>
            <a class="button secondary" href="/tools/preset-mutator/">
              <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
              Product Details
            </a>
            <a class="button secondary" href="https://kreativ.gumroad.com/l/preset-mutator-pro" target="_blank" rel="noopener noreferrer">
              <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
              Buy Pro
            </a>
          </div>
        </div>
        <a class="tools-feature-media" href="/apps/preset-mutator/ui/" aria-label="Open Preset Mutator">
          <img src="/assets/thumbs/preset-mutator.webp" width="720" height="405" alt="Preset Mutator cover artwork" loading="eager" decoding="async" />
        </a>
      </section>

      <section class="product-panel-grid tools-mode-grid" aria-label="Preset Mutator modes">
        <article class="product-panel product-panel-modern product-panel-accent">
          <p class="product-section-kicker">Default path</p>
          <h2>From Scratch</h2>
          <p>Generate a new Vital preset direction from a simple intent instead of starting from a source file.</p>
          <div class="product-actions">
            <a class="button secondary" href="/apps/preset-mutator/ui/">Open From Scratch</a>
          </div>
        </article>
        <article class="product-panel product-panel-modern">
          <p class="product-section-kicker">Preset source</p>
          <h2>Mutate Preset</h2>
          <p>Load one Vital preset and push it into related variations without losing the original sound identity.</p>
          <div class="product-actions">
            <a class="button secondary" href="/apps/preset-mutator/ui/mutate/">Open Mutate Preset</a>
          </div>
        </article>
        <article class="product-panel product-panel-modern">
          <p class="product-section-kicker">Audio source</p>
          <h2>Audio to Preset</h2>
          <p>Use one short source sound, analyze it locally, and generate Vital preset directions you can refine.</p>
          <div class="product-actions">
            <a class="button secondary" href="/apps/preset-mutator/ui/audio/">Open Audio to Preset</a>
          </div>
        </article>
      </section>
    </div>
  </section>
</BaseLayout>
