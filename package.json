{
  "name": "kreativsound.com",
  "version": "1.0.0",
  "description": "Official static website for [kreativsound.com](https://kreativsound.com).",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "sync:astro-public": "node scripts/sync-astro-public.mjs",
    "predev": "npm run sync:astro-public",
    "prebuild": "npm run sync:astro-public",
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/normalize-static-routes.mjs && npm run sitemap",
    "preview": "astro preview",
    "check": "npm run check:products && npm run check:preset-mutator && npm run build && npm run check:links && npm run sitemap:check",
    "check:products": "node scripts/check-product-data.mjs",
    "check:preset-mutator": "node scripts/check-preset-mutator.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "license:preset-mutator": "node scripts/preset-mutator-license.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "sitemap:check": "node scripts/generate-sitemap.mjs --check",
    "release:check": "bash scripts/release-gate.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aolaru/kreativsound.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/aolaru/kreativsound.com/issues"
  },
  "homepage": "https://github.com/aolaru/kreativsound.com#readme",
  "dependencies": {
    "astro": "^6.1.9"
  }
}
